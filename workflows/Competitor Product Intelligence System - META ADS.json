        "jsCode": "const now = new Date();\nconst today = String(now.getMonth() + 1).padStart(2, \"0\") + \"/\" + String(now.getDate()).padStart(2, \"0\") + \"/\" + now.getFullYear();\nconst scrapedAds = $items(\"Normalize Data\", 0).length;\nconst newAds = $items(\"Filter Node\", 0).length;\nconst rows = $items(\"Read Database2\", 0);\nconst winningAds = rows.reduce((count, row) => {\n  const rawDays = row.json.days_active;\n  const isActive = row.json.is_active;\n  if (!rawDays) return count;\n  const days = parseInt(rawDays, 10);\n  const active = isActive === true || isActive === \"true\" || isActive === 1;\n  if (!isNaN(days) && days > 2 && active) { return count + 1; }\n  return count;\n}, 0);\nreturn [{ json: { date: today, ads_scraped: scrapedAds, new_ads_found: newAds, winning_ads: winningAds } }];"
