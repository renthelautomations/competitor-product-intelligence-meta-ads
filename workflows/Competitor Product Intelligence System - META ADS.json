    {
      "parameters": {
        "jsCode": "const ads = items.map(item => item.json);\nconst now = new Date();\nconst today = String(now.getMonth() + 1).padStart(2, \"0\") + \"/\" + String(now.getDate()).padStart(2, \"0\") + \"/\" + now.getFullYear();\nconst todayAds = ads.filter(ad => ad.first_seen === today).length;\nconst grouped = {};\nads.forEach(ad => {\n  const url = ad.landing_url || \"UNKNOWN\";\n  if (!grouped[url]) { grouped[url] = { page_name: ad.page_name, landing_url: url, ad_count: 0, creatives: new Set(), start_dates: new Set(), ad_url: ad.ad_url }; }\n  grouped[url].ad_count += 1;\n  grouped[url].creatives.add(ad.creative_type);\n  grouped[url].start_dates.add(ad.start_date);\n});\nconst summary = Object.values(grouped).map(item => ({ page_name: item.page_name, landing_url: item.landing_url, ad_count: item.ad_count, creatives: Array.from(item.creatives).join(\", \"), start_dates: Array.from(item.start_dates).join(\", \"), ad_url: item.ad_url }));\nlet message = `NEW ADS SUMMARY\\n\\n`;\nmessage += `Ads Added Today: ${todayAds}\\n`;\nmessage += `Unique Products: ${summary.length}\\n\\n`;\nsummary.forEach((item, index) => {\n  message += `#${index + 1}\\n`;\n  message += `${item.page_name}\\n`;\n  message += `Creatives: ${item.creatives}\\n`;\n  message += `Ads Running: ${item.ad_count}\\n`;\n  message += `Start: ${item.start_dates}\\n`;\n  message += `${item.landing_url}\\n`;\n  message += `${item.ad_url}\\n\\n`;\n});\nreturn [{ json: { message } }];"
      },
