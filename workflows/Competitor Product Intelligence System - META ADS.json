    {
      "parameters": {
        "jsCode": "function parseDate(dateStr) {\n  if (!dateStr) return null;\n  const [month, day, year] = dateStr.split(\"/\");\n  return new Date(Number(year), Number(month) - 1, Number(day));\n}\nconst now = new Date();\nconst today = new Date(now.getFullYear(), now.getMonth(), now.getDate());\nconst todayStr = String(now.getMonth() + 1).padStart(2, \"0\") + \"/\" + String(now.getDate()).padStart(2, \"0\") + \"/\" + now.getFullYear();\nreturn items.map(item => {\n  const data = item.json;\n  const startDate = parseDate(data.start_date);\n  if (!startDate) { return { json: { ...data } }; }\n  const diffTime = today - startDate;\n  const daysActive = Math.floor(diffTime / (1000 * 60 * 60 * 24));\n  return { json: { ...data, last_seen: todayStr, status: \"UPDATED\", days_active: daysActive } };\n});"
      },
