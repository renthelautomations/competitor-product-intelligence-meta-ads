    {
      "parameters": {
        "functionCode": "return items.map(item => {\n  const ad = item.json;\n  const snap = ad.snapshot || {};\n  let landingUrl = \"\";\n  if (snap.link_url) { landingUrl = snap.link_url; }\n  else if (snap.call_to_action && snap.call_to_action.value && snap.call_to_action.value.link) { landingUrl = snap.call_to_action.value.link; }\n  if (landingUrl.includes(\"?\")) { landingUrl = landingUrl.split(\"?\")[0]; }\n  let rawDate = ad.start_date_formatted || \"\";\n  let formattedDate = rawDate ? rawDate.split(\" \")[0] : \"\";\n  const now = new Date();\n  const firstSeen = String(now.getMonth() + 1).padStart(2, \"0\") + \"/\" + String(now.getDate()).padStart(2, \"0\") + \"/\" + now.getFullYear();\n  let creativeType = \"UNKNOWN\";\n  if (snap.videos && snap.videos.length > 0) { creativeType = \"VIDEO\"; }\n  else if (snap.images && snap.images.length > 0) { creativeType = \"IMAGE\"; }\n  else { creativeType = \"TEXT\"; }\n  let isActive = false;\n  if (typeof ad.is_active === \"boolean\") { isActive = ad.is_active; }\n  else if (typeof ad.is_active === \"string\") { isActive = ad.is_active.toLowerCase() === \"true\"; }\n  else if (typeof ad.is_active === \"number\") { isActive = ad.is_active === 1; }\n  return { json: { ad_id: ad.ad_archive_id || \"\", page_name: snap.page_name || ad.page_name || ad.page_id || \"\", ad_url: ad.ad_archive_id ? `https://www.facebook.com/ads/library/?id=${ad.ad_archive_id}` : \"\", landing_url: landingUrl, start_date: formattedDate, first_seen: firstSeen, creative_type: creativeType, is_active: isActive, status: \"NEW\" } };\n});"
      },
