    {
      "parameters": {
        "jsCode": "const today = new Date();\nconst todayStr = String(today.getMonth() + 1).padStart(2, \"0\") + \"/\" + String(today.getDate()).padStart(2, \"0\") + \"/\" + today.getFullYear();\nconst existingAdIds = new Set();\nconst newAds = [];\nitems.forEach(item => {\n  const data = item.json;\n  if (data.row_number !== undefined) { if (data.ad_id) { existingAdIds.add(String(data.ad_id)); } }\n  else { newAds.push(data); }\n});\nconst seen = new Set();\nconst filtered = newAds.filter(ad => {\n  const id = String(ad.ad_id);\n  if (!id) return false;\n  if (!ad.is_active) return false;\n  const isExisting = existingAdIds.has(id);\n  if (isExisting && ad.first_seen !== todayStr) return false;\n  if (seen.has(id)) return false;\n  seen.add(id);\n  return true;\n});\nif (filtered.length === 0) { return [{ json: { message: \"No new ads (after manual edits).\" } }]; }\nreturn filtered.map(ad => ({ json: ad }));"
      },
