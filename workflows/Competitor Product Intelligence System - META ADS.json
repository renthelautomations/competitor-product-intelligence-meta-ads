        "jsCode": "const ads = items.map(item => item.json);\nconst newWinners = ads.filter(ad => {\n  const days = parseInt(ad.days_active, 10);\n  const notNotified = ad.notified_winner !== true && ad.notified_winner !== \"TRUE\";\n  return (!isNaN(days) && days === 3 && ad.status === \"UPDATED\" && notNotified);\n});\nif (newWinners.length === 0) { return [{ json: { message: \"No new winning ads detected today.\", rows_to_update: [] } }]; }\nconst grouped = {};\nnewWinners.forEach(ad => {\n  const url = ad.landing_url || \"UNKNOWN\";\n  if (!grouped[url]) { grouped[url] = { page_name: ad.page_name, landing_url: url, ad_count: 0, creatives: new Set(), ad_url: ad.ad_url, ad_ids: [] }; }\n  grouped[url].ad_count += 1;\n  grouped[url].creatives.add(ad.creative_type);\n  if (ad.ad_id) { grouped[url].ad_ids.push(ad.ad_id); }\n});\nlet message = `NEW WINNING PRODUCTS (JUST HIT 3 DAYS)\\n\\n`;\nmessage += `Total New Winners: ${Object.keys(grouped).length}\\n\\n`;\nObject.values(grouped).forEach((item, index) => {\n  message += `#${index + 1}\\n`;\n  message += `${item.page_name}\\n`;\n  message += `Ads Running: ${item.ad_count}\\n`;\n  message += `Creatives: ${Array.from(item.creatives).join(\", \")}\\n`;\n  message += `${item.landing_url}\\n`;\n  message += `${item.ad_url}\\n\\n`;\n});\nreturn [{ json: { message, ads_to_update: Object.values(grouped).flatMap(g => g.ad_ids) } }];"
      },
