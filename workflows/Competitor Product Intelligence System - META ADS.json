        "jsCode": "const ads = items.map(item => item.json);\nconst winningAds = ads.filter(ad => Number(ad.days_active) >= 3);\nif (winningAds.length === 0) { return [{ json: { message: \"No winning ads (3+ days) found today.\" } }]; }\nconst grouped = {};\nwinningAds.forEach(ad => {\n  const url = ad.landing_url;\n  if (!grouped[url]) { grouped[url] = { page_name: ad.page_name, landing_url: url, ad_count: 0, creatives: new Set(), start_dates: new Set(), max_days: 0, ad_url: ad.ad_url }; }\n  grouped[url].ad_count += 1;\n  grouped[url].creatives.add(ad.creative_type);\n  grouped[url].start_dates.add(ad.start_date);\n  const days = Number(ad.days_active);\n  if (days > grouped[url].max_days) { grouped[url].max_days = days; }\n});\nconst summary = Object.values(grouped);\nsummary.sort((a, b) => b.ad_count - a.ad_count);\nlet message = `WINNING ADS (3+ DAYS)\\n\\n`;\nmessage += `Total Winning Products: ${summary.length}\\n\\n`;\nsummary.forEach((item, index) => {\n  const score = item.ad_count >= 5 ? \"***\" : item.ad_count >= 3 ? \"**\" : \"*\";\n  message += `#${index + 1} ${score}\\n`;\n  message += `${item.page_name}\\n`;\n  message += `Days Active: ${item.max_days}\\n`;\n  message += `Ads Running: ${item.ad_count}\\n`;\n  message += `Creatives: ${Array.from(item.creatives).join(\", \")}\\n`;\n  message += `Start: ${Array.from(item.start_dates).join(\", \")}\\n`;\n  message += `${item.landing_url}\\n`;\n  message += `${item.ad_url}\\n\\n`;\n});\nreturn [{ json: { message } }];"
      },
